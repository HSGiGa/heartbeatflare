# Used by scripts/import-config.ts to push config to Cloudflare D1 via REST API.
# Required permissions: D1:Edit, Account Settings:Read
CLOUDFLARE_API_TOKEN=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Used by the Worker at runtime for the Infrastructure Usage block on the status page.
# Required permissions: D1:Read, Account Analytics:Read, Account Settings:Read
#
# Optional — to enable automatic Free vs Workers Paid plan detection:
#   add Account → Billing → Read permission to this token.
#   Without it the Worker falls back to Free plan limits (correct for most accounts).
CLOUDFLARE_GRAPHQL_API_TOKEN=

MATTERMOST_WEBHOOK_URL=
