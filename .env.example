# ============================================================================
# Deploy-time credentials — used by npm scripts (provision, config:import)
# and by CI. Never reach the deployed Worker.
# ============================================================================

# API token scopes: Workers Scripts:Edit, D1:Edit, Queues:Edit.
# Add Workers Routes:Edit and Zone:Read if deploying a custom domain route.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================================
# Runtime Worker secrets — read by the deployed Worker at request time.
# Locally they are picked up from this file (wrangler dev / vitest).
# In production, either way works (see DEPLOYMENT.md):
#   - automatic: add to GitHub/GitLab CI secrets; the secrets:sync deploy step
#     validates and pushes them to Cloudflare after every deploy
#   - manual:    npx wrangler secret put <NAME>
# ============================================================================

# Optional — enables the Infrastructure Usage block on the private status page
# and runtime email-recipient verification.
# Scopes: D1:Read, Account Analytics:Read (the latter also covers queue metrics).
# Add Account Billing:Read for automatic Free vs Workers Paid plan detection
# (falls back to Free without it).
# Add Email Routing Addresses:Read when using type: email notifications.
# Add Connectivity Directory:Read for Workers VPC network status (backing-tunnel
# health on the usage page).
CLOUDFLARE_RUNTIME_API_TOKEN=

# Cloudflare Access runtime verification. Create/configure the Access
# application manually in the Cloudflare dashboard, scoped to the /private
# path (Destination <host>/private — not the bare host, or the public page
# gets walled off too), then set these values.
CLOUDFLARE_ACCESS_TEAM_NAME=
CLOUDFLARE_ACCESS_AUD=

# ============================================================================
# Custom notification variables — any ${VAR} placeholder used in config.yaml
# (notification_channels urls, headers, tokens) must exist as a runtime secret
# with the same name. The Worker substitutes it when sending a notification;
# the secret value itself is never stored in config.yaml or D1.
# ============================================================================

# Demo receiver: create a temporary URL at https://webhook.site/ or https://beeceptor.com/.
DEMO_WEBHOOK_URL=
DEMO_WEBHOOK_TOKEN=
# MATTERMOST_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# PAGERDUTY_API_KEY=
