# Dependencies
node_modules/

# Environment secrets — never commit actual credentials
.env
.env.local
.dev.vars

# Wrangler local state (SQLite dev databases, cache)
.wrangler/

# Generated Wrangler config — produced by `npm run wrangler:generate` from wrangler.template.jsonc
wrangler.jsonc

# Auto-generated by `npm run cf-typegen` — regenerate after changing wrangler.template.jsonc
worker-configuration.d.ts

# Claude Code local config (memory, plans, project-specific settings)
.claude/

# Codx local config (memory, plans, project-specific settings)
.codex/

# Agents skills and tools
skills/

# Internal maintainer notes — not part of the OSS docs
docs/internal/

# Logs
*.log
npm-debug.log*

# OS artefacts
.DS_Store
Thumbs.db
statuspage-events.webp

# Stray binaries / installers
*.exe

# Temporary planning documents
tmp/

# Development IDE configs
.vscode/
.idea/
.zed/
